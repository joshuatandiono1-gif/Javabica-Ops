# MongoDB Atlas credentials
MONGODB_USERNAME=your_db_user
MONGODB_PASSWORD=your_db_password

# Primary connection string (SRV — recommended for Atlas)
MONGODB_URI=mongodb+srv://your_db_user:your_db_password@your-cluster.mongodb.net/?appName=YourApp

# Standard connection string (replica set)
MONGODB_URI_STANDARD=mongodb://your_db_user:your_db_password@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=your-replica-set&authSource=admin&appName=YourApp

MONGODB_DB_NAME=vibe_coding
JWT_SECRET=change-this-to-a-random-secret

# Initial admin account (created on startup if missing)
ADMIN_EMAIL=admin@javabica.com
ADMIN_PASSWORD=your-admin-password
ADMIN_NAME=Admin
